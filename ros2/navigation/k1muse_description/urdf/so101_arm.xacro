<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="so101_arm" params="prefix parent *origin">
    <xacro:property name="so101_mesh_dir" value="package://k1muse_description/meshes/so101"/>

    <material name="so101_3d_printed">
      <color rgba="1.0 0.82 0.12 1.0"/>
    </material>
    <material name="so101_sts3215">
      <color rgba="0.1 0.1 0.1 1.0"/>
    </material>

    <joint name="${prefix}mount_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}base_link"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <link name="${prefix}base_link">
      <visual>
        <origin xyz="-0.00636471 -9.94414e-05 -0.0024" rpy="1.5708 -1.67685e-15 1.5708"/>
        <geometry><mesh filename="${so101_mesh_dir}/base_motor_holder_so101_v1.stl"/></geometry>
        <material name="so101_3d_printed"/>
      </visual>
      <visual>
        <origin xyz="-0.00636471 -8.97657e-09 -0.0024" rpy="1.5708 -2.78073e-29 1.5708"/>
        <geometry><mesh filename="${so101_mesh_dir}/base_so101_v2.stl"/></geometry>
        <material name="so101_3d_printed"/>
      </visual>
      <visual>
        <origin xyz="0.0263353 -8.97657e-09 0.0437" rpy="-8.21148e-16 7.84513e-18 1.249e-15"/>
        <geometry><mesh filename="${so101_mesh_dir}/sts3215_03a_v1.stl"/></geometry>
        <material name="so101_sts3215"/>
      </visual>
      <visual>
        <origin xyz="-0.0309827 -0.000199441 0.0474" rpy="1.5708 -1.35493e-14 1.5708"/>
        <geometry><mesh filename="${so101_mesh_dir}/waveshare_mounting_plate_so101_v2.stl"/></geometry>
        <material name="so101_3d_printed"/>
      </visual>
    </link>

    <link name="${prefix}shoulder_link">
      <visual>
        <origin xyz="-0.0303992 0.000422241 -0.0417" rpy="1.5708 1.5708 0"/>
        <geometry><mesh filename="${so101_mesh_dir}/sts3215_03a_v1.stl"/></geometry>
        <material name="so101_sts3215"/>
      </visual>
      <visual>
        <origin xyz="-0.0675992 -0.000177759 0.0158499" rpy="1.5708 -1.5708 0"/>
        <geometry><mesh filename="${so101_mesh_dir}/motor_holder_so101_base_v1.stl"/></geometry>
        <material name="so101_3d_printed"/>
      </visual>
      <visual>
        <origin xyz="0.0122008 2.22413e-05 0.0464" rpy="-1.5708 2.35221e-33 0"/>
        <geometry><mesh filename="${so101_mesh_dir}/rotation_pitch_so101_v1.stl"/></geometry>
        <material name="so101_3d_printed"/>
      </visual>
    </link>

    <link name="${prefix}upper_arm_link">
      <visual>
        <origin xyz="-0.11257 -0.0155 0.0187" rpy="-3.14159 -5.27356e-16 -1.5708"/>
        <geometry><mesh filename="${so101_mesh_dir}/sts3215_03a_v1.stl"/></geometry>
        <material name="so101_sts3215"/>
      </visual>
      <visual>
        <origin xyz="-0.065085 0.012 0.0182" rpy="3.14159 0 0"/>
        <geometry><mesh filename="${so101_mesh_dir}/upper_arm_so101_v1.stl"/></geometry>
        <material name="so101_3d_printed"/>
      </visual>
    </link>

    <link name="${prefix}lower_arm_link">
      <visual>
        <origin xyz="-0.0648499 -0.032 0.0182" rpy="3.14159 0 0"/>
        <geometry><mesh filename="${so101_mesh_dir}/under_arm_so101_v1.stl"/></geometry>
        <material name="so101_3d_printed"/>
      </visual>
      <visual>
        <origin xyz="-0.0648499 -0.032 0.018" rpy="-3.14159 -2.55351e-15 0"/>
        <geometry><mesh filename="${so101_mesh_dir}/motor_holder_so101_wrist_v1.stl"/></geometry>
        <material name="so101_3d_printed"/>
      </visual>
      <visual>
        <origin xyz="-0.1224 0.0052 0.0187" rpy="-3.14159 0 -3.14159"/>
        <geometry><mesh filename="${so101_mesh_dir}/sts3215_03a_v1.stl"/></geometry>
        <material name="so101_sts3215"/>
      </visual>
    </link>

    <link name="${prefix}wrist_link">
      <visual>
        <origin xyz="8.32667e-17 -0.0424 0.0306" rpy="1.5708 1.5708 0"/>
        <geometry><mesh filename="${so101_mesh_dir}/sts3215_03a_no_horn_v1.stl"/></geometry>
        <material name="so101_sts3215"/>
      </visual>
      <visual>
        <origin xyz="0 -0.028 0.0181" rpy="-1.5708 -1.5708 0"/>
        <geometry><mesh filename="${so101_mesh_dir}/wrist_roll_pitch_so101_v2.stl"/></geometry>
        <material name="so101_3d_printed"/>
      </visual>
    </link>

    <link name="${prefix}gripper_link">
      <visual>
        <origin xyz="0.0077 0.0001 -0.0234" rpy="-1.5708 -5.19179e-17 -1.66533e-16"/>
        <geometry><mesh filename="${so101_mesh_dir}/sts3215_03a_v1.stl"/></geometry>
        <material name="so101_sts3215"/>
      </visual>
      <visual>
        <origin xyz="8.32667e-17 -0.000218214 0.000949706" rpy="-3.14159 -5.55112e-17 0"/>
        <geometry><mesh filename="${so101_mesh_dir}/wrist_roll_follower_so101_v1.stl"/></geometry>
        <material name="so101_3d_printed"/>
      </visual>
    </link>

    <link name="${prefix}tool0"/>

    <link name="${prefix}moving_jaw_link">
      <visual>
        <origin xyz="-5.55112e-17 -5.55112e-17 0.0189" rpy="0 0 0"/>
        <geometry><mesh filename="${so101_mesh_dir}/moving_jaw_so101_v1.stl"/></geometry>
        <material name="so101_3d_printed"/>
      </visual>
    </link>

    <joint name="${prefix}shoulder_pan" type="revolute">
      <origin xyz="0.0388353 -8.97657e-09 0.0624" rpy="3.14159 4.18253e-17 -3.14159"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}shoulder_link"/>
      <axis xyz="0 0 1"/>
      <limit effort="10" velocity="10" lower="-1.78708768" upper="2.00031114"/>
    </joint>

    <joint name="${prefix}shoulder_lift" type="revolute">
      <origin xyz="-0.0303992 -0.0182778 -0.0542" rpy="-1.5708 -1.5708 0"/>
      <parent link="${prefix}shoulder_link"/>
      <child link="${prefix}upper_arm_link"/>
      <axis xyz="0 0 1"/>
      <limit effort="10" velocity="10" lower="-1.76561201" upper="1.67357314"/>
    </joint>

    <joint name="${prefix}elbow_flex" type="revolute">
      <origin xyz="-0.11257 -0.028 1.73763e-16" rpy="-3.63608e-16 8.74301e-16 1.5708"/>
      <parent link="${prefix}upper_arm_link"/>
      <child link="${prefix}lower_arm_link"/>
      <axis xyz="0 0 1"/>
      <limit effort="10" velocity="10" lower="-1.64442742" upper="1.48335946"/>
    </joint>

    <joint name="${prefix}wrist_flex" type="revolute">
      <origin xyz="-0.1349 0.0052 3.62355e-17" rpy="4.02456e-15 8.67362e-16 -1.5708"/>
      <parent link="${prefix}lower_arm_link"/>
      <child link="${prefix}wrist_link"/>
      <axis xyz="0 0 1"/>
      <limit effort="10" velocity="10" lower="-1.64749539" upper="1.63522363"/>
    </joint>

    <joint name="${prefix}wrist_roll" type="revolute">
      <origin xyz="5.55112e-17 -0.0611 0.0181" rpy="1.5708 0.0486795 3.14159"/>
      <parent link="${prefix}wrist_link"/>
      <child link="${prefix}gripper_link"/>
      <axis xyz="0 0 1"/>
      <limit effort="10" velocity="10" lower="-2.63691306" upper="2.62770915"/>
    </joint>

    <joint name="${prefix}tool0_fixed" type="fixed">
      <origin xyz="0 0 -0.0981274" rpy="0 3.14159 0"/>
      <parent link="${prefix}gripper_link"/>
      <child link="${prefix}tool0"/>
    </joint>

    <joint name="${prefix}gripper" type="revolute">
      <origin xyz="0.0202 0.0188 -0.0234" rpy="1.5708 -5.24284e-08 -1.41553e-15"/>
      <parent link="${prefix}gripper_link"/>
      <child link="${prefix}moving_jaw_link"/>
      <axis xyz="0 0 1"/>
      <limit effort="10" velocity="10" lower="-0.167203918" upper="1.88833046"/>
    </joint>
  </xacro:macro>
</robot>
